{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!company-logo\\.png|hema-logo\\.png|favicon\\.ico|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
